# ── REQUIRED ──────────────────────────────────────────────────────────────────

# LiveKit (get from cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# LLM — at least one required
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=                         # optional fallback

# Speech (get from sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key

# Calendar (get from cal.com/settings/developer)
CAL_API_KEY=your_cal_api_key
CAL_EVENT_TYPE_ID=your_event_type_id_number

# Database (get from supabase.com project settings)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── TELEPHONY (VoBiz SIP) ─────────────────────────────────────────────────────
SIP_TRUNK_ID=                         # LiveKit SIP trunk ID (after setup)
VOBIZ_SIP_DOMAIN=sip.vobiz.in        # your VoBiz SIP domain
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX # number to transfer calls to human agent

# ── OPTIONAL — Call Recording (Supabase Storage S3) ──────────────────────────
# Leave empty to disable recording
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_ENDPOINT=https://xxxx.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1
